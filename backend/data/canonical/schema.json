{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BCREC Canonical Knowledge Base Schema",
  "description": "Every factual value in the canonical KB wraps a value with provenance metadata.",
  "definitions": {
    "provenance": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["official_document", "website", "manual_entry", "inferred", "ai_generated", "historical"]
        },
        "source_url": { "type": "string" },
        "date_verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "notes": { "type": "string" }
      },
      "required": ["source_type", "date_verified", "confidence"]
    },
    "provenance_value": {
      "description": "A value wrapped with provenance metadata, optional history, and conflict status.",
      "type": "object",
      "properties": {
        "value": {},
        "provenance": { "$ref": "#/definitions/provenance" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": {},
              "valid_from": { "type": "string" },
              "valid_to": { "type": "string" }
            }
          }
        },
        "conflict_status": {
          "type": "string",
          "enum": ["resolved", "unresolved", "not_applicable"]
        }
      },
      "required": ["value", "provenance"],
      "not": {
        "anyOf": [
          { "required": ["conflict_status"], "properties": { "conflict_status": { "const": "unresolved" } } }
        ]
      }
    },
    "trilingual": {
      "type": "object",
      "properties": {
        "en": { "type": "string" },
        "hi": { "type": "string" },
        "bn": { "type": "string" }
      },
      "required": ["en", "hi", "bn"]
    }
  },
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "last_updated": { "type": "string" },
        "schema_version": { "type": "string" }
      },
      "required": ["version", "last_updated", "schema_version"]
    },
    "college": { "type": "object" },
    "principal": { "type": "object" },
    "vice_principal": { "type": "object" },
    "courses": { "type": "object" },
    "fees_summary": { "type": "object" },
    "admission": { "type": "object" },
    "infrastructure": { "type": "object" },
    "student_life": { "type": "object" },
    "placements": { "type": "object" },
    "hostel": { "type": "object" },
    "scholarships": { "type": "object" },
    "anti_ragging": { "type": "object" },
    "academics": { "type": "object" },
    "departments": { "type": "object" },
    "admission_documents": { "type": "object" }
  },
  "required": [
    "meta", "college", "principal", "courses", "admission",
    "infrastructure", "student_life", "placements", "hostel",
    "scholarships", "anti_ragging", "academics", "departments"
  ]
}
