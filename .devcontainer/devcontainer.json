{
  "name": "College Voice Agent",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.10" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": { "version": "latest", "moby": true }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [8000, 3010, 8001],
  "portsAttributes": {
    "8000": { "label": "Backend API" },
    "3010": { "label": "Dograh UI", "onAutoForward": "openBrowser" },
    "8001": { "label": "Dograh API" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-azuretools.vscode-docker"]
    }
  }
}
