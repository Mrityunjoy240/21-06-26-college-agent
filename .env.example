# ============================================================
# COLLEGE VOICE AGENT - Environment Configuration
# ============================================================

# ===== Backend (FastAPI RAG) =====
GROQ_API_KEY=
SARVAM_API_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SECRET_KEY=change-this-to-a-random-secret
COLLEGE_NAME=Dr. B.C. Roy Engineering College
ADMISSIONS_PHONE=+91-9333928874
SUPPORT_EMAIL=info@bcrengg.edu.in

# ===== Dograh Voice Agent Platform =====
POSTGRES_PASSWORD=postgres
REDIS_PASSWORD=redissecret

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
OSS_JWT_SECRET=

# Set to your public URL if deploying remotely
BACKEND_API_ENDPOINT=http://localhost:8000
BACKEND_URL=http://dograh-api:8000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Dograh image registry (change to your forked registry after white-labeling)
DOGRAH_REGISTRY=ghcr.io/dograh-hq
DOGRAH_VERSION=latest
FASTAPI_WORKERS=1
ENVIRONMENT=local
ENABLE_TELEMETRY=false

# TURN server (required only for remote WebRTC calls)
TURN_HOST=
TURN_SECRET=
FORCE_TURN_RELAY=false
